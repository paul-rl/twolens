# =============================================================================
# TwoLens: Environment Configuration
# =============================================================================

# --- GCP / BigQuery ---
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your-service-account-key.json
GCP_PROJECT_ID=your-gcp-project-id
BQ_DATASET=twolens

# --- NewsAPI (Lens 1: Media Coverage) ---
# Key from: https://newsapi.org/register
# Free tier: 100 requests/day, articles delayed 24h
NEWSAPI_KEY=your_newsapi_key_here

# --- YouTube Data API v3 (Lens 2: Creator & Consumer Voice) ---
# Key from: GCP Console
# Free tier: 10,000 units/day (search.list = 100 units, videos.list = 1 unit)
YOUTUBE_API_KEY=your_youtube_api_key_here

# --- Notifications ---
# Slack webhook for pipeline failure alerts
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your_webhook_here

# --- Pipeline Config ---
# Comma-separated brand names to monitor
QUERY_TERMS=Avenue Z,Anthropic,OpenAI
# Maximum results per API per query term per run
MAX_RESULTS_PER_QUERY=25
